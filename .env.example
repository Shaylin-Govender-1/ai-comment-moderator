# --- Required ---
# Your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional (sensible defaults shown) ---

# Model used for moderation.
MODERATION_MODEL=claude-sonnet-4-6

# Maximum length (characters) of a comment or appeal accepted by the API.
MAX_COMMENT_LENGTH=10000

# Per-user rate limit applied to /moderate and /appeal, e.g. "10/minute".
RATE_LIMIT=10/minute

# Set to "false" to disable rate limiting entirely.
RATE_LIMIT_ENABLED=true

# Where the file-based moderation log is persisted.
LOG_FILE=moderation_log.json

# Optional webhook. If set, a JSON payload is POSTed here whenever a comment
# is flagged_for_review. Leave blank to disable.
WEBHOOK_URL=

# How long (seconds) to wait on the LLM before falling back.
LLM_TIMEOUT_SECONDS=30
